# syntax=docker/dockerfile:1.7
FROM alpine:3.23

RUN apk --no-cache add ca-certificates tzdata \
    && adduser -D -s /bin/sh migration

WORKDIR /app

COPY mongork /usr/local/bin/mongork
RUN ln -sf /usr/local/bin/mongork /usr/local/bin/mongo \
    && ln -sf /usr/local/bin/mongork /usr/local/bin/mmo

USER migration

ENTRYPOINT ["/usr/local/bin/mongo"]
CMD ["--help"]
